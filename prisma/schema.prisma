// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (Pilihan Terbatas)
// ==========================================

enum CampusLocation {
  INDUK   // Kampus Induk 2 & 4
  TERPADU // Kampus Terpadu 1, 3, & 5
}

enum Role {
  ADMIN
  MENTOR
}

enum AttendanceStatus {
  HADIR
  SAKIT
  IZIN
  ALPHA
}

// ==========================================
// DATA MODELS
// ==========================================

// 1. User (Pengguna Sistem: Admin & Guru)
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(MENTOR)
  
  // Relasi: Guru ini mengampu ekskul apa saja? (Bisa banyak)
  mentoringExculs Excul[] 

  // Relasi: Presensi yang pernah dicatat oleh user ini
  recordedAttendances Attendance[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Ekskul (Master Data Mata Pelajaran Ekstra)
// Contoh: "Futsal - Induk", "Robotik - Terpadu"
model Excul {
  id        String         @id @default(cuid())
  name      String         // Contoh: "Futsal", "Robotik"
  location  CampusLocation // INDUK atau TERPADU
  
  // Relasi: Guru pengampunya siapa?
  mentors   User[]         
  
  // Relasi: Siswa yang terdaftar di ekskul ini
  students  Student[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 3. Siswa (Peserta Ekskul)
// Siswa terikat pada satu ekskul spesifik.
model Student {
  id        String   @id @default(cuid())
  name      String
  nis       String?  
  class     String   // Contoh: "10 MIPA 1"
  isActive  Boolean  @default(true)
  
  // Relasi: Anggota ekskul apa?
  exculId   String
  excul     Excul    @relation(fields: [exculId], references: [id], onDelete: Cascade)

  // Relasi: Riwayat kehadiran
  attendances Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@index([exculId]) // Optimasi pencarian
}

// 4. Presensi (Pencatatan Kehadiran)
model Attendance {
  id            String           @id @default(cuid())
  date          DateTime
  status        AttendanceStatus
  notes         String?
  proofImageUrl String?          // Foto bukti kegiatan (Opsional)
  
  studentId     String
  student       Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  recorderId    String
  recorder      User    @relation(fields: [recorderId], references: [id])

  createdAt     DateTime @default(now())

  @@index([date])
  @@index([studentId])
}

// 5. Company Profile (CMS - Konten Dinamis Website)
// Tabel ini hanya akan punya 1 baris data yang diedit terus menerus.
model CompanyProfile {
  id              Int      @id @default(1)
  schoolName      String   @default("Madrasah Mu'allimin Muhammadiyah")
  
  // -- BRANDING --
  logoUrl         String?  @default("/logo.png")
  
  // -- LANDING PAGE: HERO SECTION --
  heroTitle       String   @default("Wadah Kreativitas")
  heroSubtitle    String   @default("Kader Pemimpin")
  heroDescription String   @db.Text
  heroImageUrl    String?  // Foto besar di halaman depan

  // -- LANDING PAGE: ABOUT & FOOTER --
  aboutText       String   @db.Text
  address         String?
  email           String?
  phone           String?
  website         String?

  // -- LOGIN PAGE --
  loginImageUrl   String?  // Foto samping form login
  loginQuote      String?  @db.Text 
  loginQuoteAuthor String? // Tokoh yang mengucapkannya

  updatedAt       DateTime @updatedAt
}

// 6. Galeri (Foto Kegiatan di Halaman Depan)
model Gallery {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  createdAt DateTime @default(now())
}